# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Raw WAV stems (incl. the 124 MB + 73 MB pads) are the source of truth and are
# tracked via Git LFS (see .gitattributes). The *shipped* audio the site serves
# is the compressed set in public/audio/prism (built by scripts/build-audio.mjs).

# Original testimonial photos (optimized copies live in public/testimonials).
/testimonial_images/
